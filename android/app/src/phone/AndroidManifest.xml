<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Telefon versiyonu - Wear OS özelliğini kaldır -->
    <uses-feature 
        android:name="android.hardware.type.watch" 
        tools:node="remove" />
    
    <application>
        <!-- Data Layer: path filtreli DATA_CHANGED (BIND_LISTENER release lint’te fatal). -->
        <service
            android:name="com.nmodev.pomodoro.DataLayerListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/pomodoro" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/total" />
            </intent-filter>
        </service>
        
    </application>
</manifest>